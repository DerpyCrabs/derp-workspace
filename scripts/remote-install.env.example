# Copy to scripts/remote-install.env and adjust (that file is gitignored).
#
#   cp scripts/remote-install.env.example scripts/remote-install.env

# Remote login (examples only — put your real values in remote-install.env)
# Same variables are used by scripts/list-derp-logs.sh (SSH + cd REMOTE_REPO).
REMOTE_USER=alice
REMOTE_HOST=192.0.2.1
REMOTE_REPO=/home/alice/derp-workspace

# Before `install-system.sh` runs `git pull`, stash local edits to scripts/derp-session.sh
# if the file is dirty (avoids merge abort). Set to 0 to disable.
STASH_DERP_SESSION=1

# quick_shell runs remote npm ci + npm run build by default (tar does not sync node_modules).
# Set to 0 only if the remote loads Vite HMR from a dev machine (DERP_CEF_SHELL_DOCUMENT_URL):
# DERP_REMOTE_BUILD_SHELL=0
