# Optional — only if you need overrides:
#   cp scripts/derp-session.local.env.example scripts/derp-session.local.env
#
# CEF flags for the shell sidecar are set in `derp-session.sh` (--command env). Use this file for
# RUST_LOG, DERP_*, etc. Compositor spawns XWayland before `--command` unless DERP_XWAYLAND=0.
#
# Optional:
# export DERP_PERF_SESSION=1
# export RUST_LOG=warn,derp_input=debug,derp_shell_osr=info,shell_ipc=trace
#
# dma-buf OSR / Chromium stderr spam (every frame + --v=2): enable only while debugging.
# export DERP_SESSION_DMABUF_LOGS=1
