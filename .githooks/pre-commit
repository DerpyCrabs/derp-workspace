#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

if ! command -v cargo >/dev/null 2>&1; then
  echo "pre-commit: cargo not found" >&2
  exit 1
fi

staged_rs="$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')"
if [[ -z "$staged_rs" ]]; then
  exit 0
fi

cargo fmt --all

while IFS= read -r path; do
  if [[ -n "$path" ]]; then
    git add -- "$path"
  fi
done <<< "$staged_rs"
